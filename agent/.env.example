# Copiez ce fichier en .env et remplissez les valeurs.
# ⚠️ .env reste SUR VOTRE MACHINE (il est ignoré par git). Ne le partagez pas.

SUPABASE_URL=https://VOTRE-PROJET.supabase.co

# Clé SECRÈTE Supabase (service_role ou sb_secret_...) : Project Settings > API Keys.
# Elle contourne la sécurité RLS pour écrire les annonces. Gardez-la privée.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# L'e-mail de VOTRE compte ChercheAppart (celui de connexion au site).
OWNER_EMAIL=vous@exemple.fr

# true = navigateur invisible (par défaut). Si DataDome bloque en headless,
# mettez false : une fenêtre de navigateur s'ouvrira brièvement (plus robuste).
HEADLESS=true
