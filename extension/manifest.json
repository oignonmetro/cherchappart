{
  "manifest_version": 3,
  "name": "ChercheAppart — Alertes Leboncoin/PAP/SeLoger",
  "version": "1.0.0",
  "description": "Détecte les nouvelles annonces sur vos recherches sauvegardées (Leboncoin, PAP, SeLoger) depuis votre propre navigateur et les envoie vers ChercheAppart.",
  "action": {},
  "options_page": "options.html",
  "permissions": ["alarms", "storage", "tabs"],
  "host_permissions": [
    "https://www.leboncoin.fr/*",
    "https://www.seloger.com/*",
    "https://www.pap.fr/*",
    "https://oignonmetro.github.io/*",
    "https://plxzievikemytnssnqxm.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.leboncoin.fr/*",
        "https://www.seloger.com/*",
        "https://www.pap.fr/*"
      ],
      "js": ["content-watch.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://oignonmetro.github.io/cherchappart/*"],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
